# gembachain.io contact-form backend. Copy to .env and fill SMTP_PASS + TURNSTILE_SECRET.
# Sends as noreply@ (auth = sender, required by the mail server). NEVER commit the real .env.
PORT=3115
SMTP_HOST=mail.gembamail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gembachain.io
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@gembachain.io
SMTP_FROM_NAME=GembaBlockchain
CONTACT_EMAIL=contacts@gembachain.io
# Cloudflare Turnstile secret (server-side). Site key is public, in the landing frontend.
TURNSTILE_SECRET=
