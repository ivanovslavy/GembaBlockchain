# blockchain-notifier — copy to .env and fill. The SAME file shape serves testnet and mainnet;
# only NETWORK + the endpoints/SMTP differ. NEVER commit the real .env (it holds the SMTP password).

# ---- environment switch (drives the TESTNET/MAINNET label in every email) ----
NETWORK=testnet                 # testnet | mainnet
GEMBA_CHAIN_ID=821207           # mainnet: the mainnet EVM chainId
COSMOS_CHAIN_ID=gemba-testnet-1

# ---- chain endpoints ----
EVM_RPC=https://rpc1.gembascan.io
# Cosmos REST for validator/slashing/pool data. 1317 is firewalled; open it to THIS host only
# (Option A: ufw allow from <notifier-host-ip> to <archive .137> port 1317).
COSMOS_REST=http://13.140.148.137:1317
EXPLORER_URL=https://testnet.gembascan.io
UPTIME_URLS=https://rpc1.gembascan.io,https://rpc2.gembascan.io,https://rpc3.gembascan.io,https://testnet.gembascan.io
DENOM=agmb

# ---- watched contract: GembaPay GMB dispenser (its Dispensed event = "GMB sold") ----
GEMBA_DISPENSER_ADDRESS=0x0EB298466F862E548d2416a75d3D108E503bD2Cf

# non-voting reserves excluded from "circulating" for the bonded-ratio KPI (add foundation/dao/
# contingency/founder module addrs for a fuller picture)
RESERVE_ADDRESSES=cosmos1s32mhm7c0eest48njscsr5fnn2c42mr9w8cnqe,cosmos17s95c5jpc6x2l3edwh4dm8yhac68yru7cre47d

# ---- email (PENDING: gembachain.io domain + mailboxes are being created) ----
# Sender encodes the environment; recipient is the monitored mailbox. Same SMTP creds as the
# gembachain.io contact form; only the sender/recipient differ.
SMTP_HOST=                      # e.g. smtp.<provider>.com   (leave blank => DRY-RUN: logs, never sends)
SMTP_PORT=587
SMTP_USER=testnet@gembachain.io
SMTP_PASS=                      # the mailbox password (secret)
MAIL_FROM=testnet@gembachain.io # mainnet instance: mainnet@gembachain.io
MAIL_TO=contacts@gembachain.io

# ---- polling ----
POLL_MS=30000
UPTIME_POLL_MS=120000
ALERT_COOLDOWN_MS=10800000      # re-notify a still-firing alert every 3h

# ---- alarm thresholds (see docs/notifications-implementation-plan.md for the math) ----
TH_VAL_SHARE_WARN=0.30
TH_VAL_SHARE_CRIT=0.3334
TH_MIN_VALIDATORS=4
TH_BONDED_WARN=0.50
TH_BONDED_CRIT=0.33
TH_SALE_FRAC_WARN=0.10
TH_SALE_FRAC_CRIT=0.25
TH_SHARE_RISE_PP=5
TH_BONDED_DROP_PP=10

# DRY_RUN=1                      # force dry-run even with SMTP set (testing)
