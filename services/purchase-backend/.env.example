# GMB purchase backend. Copy to .env; fill the GembaPay key/secret + the dispenser owner key.
# NEVER commit the real .env (it holds the API key, webhook secret and the dispenser owner key).
PORT=3116
GEMBAPAY_API_BASE=https://api.gembapay.com
GEMBAPAY_API_KEY=            # gembapay_test_... (testnet) / gembapay_live_... (mainnet)
GEMBAPAY_WEBHOOK_SECRET=     # whsec_... (HMAC-SHA256 over the raw webhook body)
GEMBAPAY_CHECKOUT_BASE=https://payment.gembapay.com
# pricing — EUR per GMB (testnet placeholder; set the real rate for mainnet)
GMB_PRICE_EUR=0.10
MIN_GMB=10
MAX_GMB=10000
GEMBA_RPC_URL=https://rpc1.gembascan.io
GEMBA_CHAIN_ID=821207
GEMBA_DISPENSER_ADDRESS=0x0EB298466F862E548d2416a75d3D108E503bD2Cf
GEMBA_DISPENSER_OWNER_PK=    # the GembaPayDispenser owner key (gitignored; also in wallet-backup/)
