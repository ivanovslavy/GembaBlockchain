# --- GembaBlockchain stress harness config (copy to .env; .env is gitignored) ---

# RPC endpoints (comma-separated). Run ON .83 → use the local node first.
# Add other nodes' :8545 if reachable to spread RPC-ingestion load across the network.
RPC_URLS=http://127.0.0.1:8545
WS_URL=ws://127.0.0.1:8546
# CometBFT RPC for mempool/consensus health probing
COMETBFT_RPC=http://127.0.0.1:26657

CHAIN_ID=821207

# Funder: a wallet pre-seeded from the testnet faucet/founder. It Disperses GMB to
# the generated worker wallets. NEVER commit. (Set in .env only.)
FUNDER_PK=

# Wallet pool
WALLET_COUNT=300
# GMB funded to each worker wallet (must cover its share of gas; testnet base fee ~1 gwei)
FUND_PER_WALLET=2.0

# Max unconfirmed txs per wallet (local nonce must not outrun mined nonce — see README).
MAX_INFLIGHT_PER_WALLET=4

# Gas (EIP-1559). base-fee floor on testnet ~1 gwei.
MAX_FEE_GWEI=3
PRIORITY_FEE_GWEI=1

# Safety: abort if the node data dir free space drops below this (GB). Disk is 75GB.
NODE_DATA_DIR=/root/.gembad/data
DISK_MIN_FREE_GB=12

# State-growth caps (keep the 4h soak from bloating 75GB)
MAX_NFT_SUPPLY=200000

# Logging
LOG_DIR=./logs
LOG_ROTATE_LINES=200000     # gzip-rotate tx.jsonl every N lines

# Blockscout verify (optional, step 03)
EXPLORER_API=https://testnet.gembascan.io/api
