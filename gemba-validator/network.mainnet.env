# =============================================================================
# network.mainnet.env — Gemba MAINNET (gemba-1) network parameters (single source
# of truth for the installer). Edit only if you know what you are doing.
#
# STATUS: pre-launch template. Two values are INTENTIONALLY blank until the
# genesis ceremony produces them (docs/runbooks/mainnet-genesis-ceremony.md):
#   GENESIS_SHA256 — hash printed by `init-gembad-mainnet.sh collect` (publish it)
#   SEEDS          — node-id@ip:26656 of the 4 genesis validators, known after
#                    each box runs `gembad comet show-node-id`
# The installer must REFUSE to run while either is blank.
# =============================================================================

# Identity — Cosmos chain-id gemba-1, display name "Gemba" (owner 2026-07-17)
NETWORK="gemba-1"
CHAIN_ID="gemba-1"
EVM_CHAIN_ID="821206"

# Genesis (bundled next to this file; sha256 is enforced by the installer)
GENESIS_SHA256=""   # FILL at ceremony: sha256 from init-gembad-mainnet.sh collect

# Public seeds (the 4 genesis validators; P2P TCP 26656).
# Mainnet RPC domains (Apache vhosts on the same boxes): gmb1.gembascan.io -> .82,
# gmb2 -> .83, gmb3 -> .84 (owner 2026-07-17 — fresh names; rpc1/2/3 stay testnet).
SEEDS=""            # FILL at ceremony: id@ip:26656,... from `gembad comet show-node-id`

# Build-from-source: the node source is BUNDLED in ./src/chain (self-contained).
# The binary is built on YOUR machine -> matches your glibc. build-gembad.sh also
# fetches the pinned, PUBLIC cosmos/evm at build time.
GO_VERSION="1.25.9"

# Node config — mainnet fee floor is 5 gwei (genesis feemarket.min_gas_price;
# the node mempool floor must be >= it, CLAUDE.md §11 / ADR-008a)
MIN_GAS_PRICES="5000000000agmb"
PRUNING="custom"                  # validators prune; explorer/archive use "nothing"
# I4 disk-fill hardening (mainnet launches with this from block 0 — the testnet
# .82 72G overfill was the root cause; see mainnet-launch-hardening.md §D I4).
PRUNING_KEEP_RECENT="100000"      # ~3 days of STATE @ ~2.4s (bounded ~10G)
PRUNING_INTERVAL="10"
MIN_RETAIN_BLOCKS="100000"        # ~3 days of BLOCKS — archive catch-up window after an outage
TX_INDEX="null"                   # CometBFT tx index OFF on validators (Blockscout searches)
MIN_SELF_BOND_GMB="1000"          # §5.2 — min self-delegation to create a validator

# Explorer (handy links)
EXPLORER_URL="https://gembascan.io"
