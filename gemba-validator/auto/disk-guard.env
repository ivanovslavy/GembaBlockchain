# gemba-disk-guard.sh config. Copy to /etc/gemba/disk-guard.env on EVERY box and adjust MOUNTS.
DISK_MOUNTS="/"                 # space-separated mounts to watch (e.g. "/ /var/lib/docker" on the explorer)
DISK_WARN_PCT=85               # email a WARNING at/above this %
DISK_CRIT_PCT=95              # email a CRITICAL at/above this % (imminent write-crash)
DISK_ALERT_REPEAT_SEC=21600    # while still over threshold, re-email at most this often (6h)
NOTIFY_CMD=/usr/local/bin/gemba-alert-email.sh   # email sink (see notify.env). Leave default.
# First-aid on CRIT (safe, reversible) — vacuum journald if it is the space hog. Off by default.
DISK_GUARD_VACUUM_JOURNAL=false
DISK_GUARD_JOURNAL_CAP=200M
LOG_FILE=/var/log/gemba-disk-guard.log
