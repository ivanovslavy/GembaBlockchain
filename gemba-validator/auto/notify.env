# Operator alert email (SMTP) — used by gemba-alert-email.sh (disk-guard, node-watchdog, and the
# validator watchdog's jail/give-up alerts all funnel here). Copy to /etc/gemba/notify.env on each
# box and fill in. Reuses the gembascan.io contact-form SMTP account, SAME as monitoring/alertmanager.yml.
#
# SECRET: the SMTP password is NOT here. Provision it separately, root-owned + gitignored:
#     printf %s '<smtp-password>' > /etc/gemba/smtp_password && chmod 600 /etc/gemba/smtp_password
# (You can reuse /etc/alertmanager/smtp_password if that is already provisioned — point SMTP_PASS_FILE at it.)

SMTP_HOST=mail.gembamail.com   # gembachain.io mailbox host (same account as services/blockchain-notifier)
SMTP_PORT=587
SMTP_FROM=noreply@gembachain.io
SMTP_USER=noreply@gembachain.io
SMTP_PASS_FILE=/etc/gemba/smtp_password
ALERT_TO=ivanovslavy@gmail.com
# NOTE: quote any value with spaces/brackets — env files are `source`d (unquoted brackets = a broken assign).
ALERT_SUBJECT_PREFIX="[GembaChain alert]"
