# Config for the GembaBlockchain validator auto-ops daemons (auto-unjail + auto-compound).
# Copy to the validator box and edit; the systemd units load it via EnvironmentFile.
# These are OPERATOR tools for YOUR OWN validators — they sign with the operator key.

GEMBAD=/usr/local/bin/gembad
GEMBAD_HOME=/root/.gembad
VAL_KEY=valop                 # operator key name in the keyring
KEYRING_BACKEND=test
CHAIN_ID=gemba-testnet-1       # mainnet: gemba-1
NODE=tcp://localhost:26657
RPC_HTTP=http://localhost:26657
DENOM=agmb

# --- auto-compound ---
# Re-stake this % of the rewards withdrawn each run back into the validator's OWN
# self-delegation, so the validator continuously strengthens (defends the ~66% bonded
# quorum — §16.8). The rest stays liquid for fees/ops.
REINVEST_PCT=50
MIN_REINVEST_AGMB=1000000000000000000     # 1 GMB — skip dust runs (don't waste a tx fee)
# §6 daily bond-increase cap: clamp the daily re-stake to this so the on-chain valgate ante never
# rejects the compound (it delegates the max allowed, never errors). Match the chain param.
MAX_DAILY_ADD_AGMB=50000000000000000000   # 50 GMB

# --- tx fees ---
# Offer >= the chain's min-gas-price floor or the tx is rejected by the mempool. MAINNET (and the
# devnet params) set a 5 gwei floor (gemba.params.sh MIN_GAS_PRICE, regenesis 2026-06-26); the old
# 1 gwei here would be rejected on mainnet. 5 gwei is safe everywhere (EIP-1559 charges the actual
# base fee, so offering above the floor on a cheaper chain costs no more).
GAS_PRICES=5000000000agmb

# --- watchdog: detect-stuck -> restart -> (sync) -> unjail (auto-unjail.sh, layers 1/2) ---
# The old script only unjailed; it could not recover a node that lost its peers and froze
# (a frozen node reports "not jailed" from its stale height, so nothing happened). These knobs
# drive the restart layer that fixes that. Safe defaults; only RESTART_CMD usually needs setting.
ENABLE_AUTO_RESTART=true
# How to restart THIS box's node. MUST be quoted (the value has spaces).
# Contabo systemd: "systemctl restart gembad-val".
# Home box / Docker-under-systemd (val-3/.208): "systemctl restart gembad".
RESTART_CMD="systemctl restart gembad"
# External network tip = PUBLIC EVM RPC (raw CometBFT 26657 is intentionally not public).
# Space-separated; tried in order. Leave empty to use local-only stuck signals (peers==0 /
# height-not-advancing), which already catch the real failure mode. Mainnet: gmb1/2/3.gembascan.io.
TIP_EVM_RPCS="https://rpc1.gembascan.io https://rpc2.gembascan.io https://rpc3.gembascan.io"
LOCAL_EVM_RPC=http://localhost:8545       # for an apples-to-apples local-vs-tip gap (optional)
STUCK_BEHIND_BLOCKS=100                    # behind the tip by more than this AND not advancing => stuck
SYNC_MARGIN_BLOCKS=25                      # within this of the tip counts as "caught up" for unjail
RESTART_COOLDOWN_SEC=900                   # min seconds between restarts (backoff)
MAX_CONSECUTIVE_RESTARTS=4                 # after this many with no recovery, STOP + alert (won't fix disk/corruption by restarting)
STATE_FILE=/var/lib/gemba/auto-unjail.state
# Alert hook, run directly as `$NOTIFY_CMD "<message>"` on jail, recovery, restart, and give-up.
# Default = the shared email sink (gemba-alert-email.sh -> gembascan.io SMTP -> your inbox; see notify.env).
# Set empty to disable email for this box.
NOTIFY_CMD=/usr/local/bin/gemba-alert-email.sh

# --- logs ---
LOG_FILE=/var/log/gemba-validator-auto.log
