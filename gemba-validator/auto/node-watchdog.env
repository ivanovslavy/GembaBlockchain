# gemba-node-watchdog.sh config (detect-stuck -> restart, NO unjail). For NON-validator full nodes
# — the archive, a public RPC source. Copy to /etc/gemba/node-watchdog.env and set RESTART_CMD.
NODE_LABEL=archive
# MUST match this node's ACTUAL CometBFT RPC port (grep '^laddr' config/config.toml).
# Standard nodes use 26657, but the testnet archive runs on OFFSET ports (rpc 26667 / p2p 26666) —
# a wrong port makes every tick read "RPC unreachable" and needlessly restart a healthy node.
RPC_HTTP=http://localhost:26667
ENABLE_AUTO_RESTART=true
RESTART_CMD="systemctl restart gembad-archive"   # the node's systemd unit on THIS box
# External tip = public EVM RPC (optional; local peers/frozen signals work without it).
TIP_EVM_RPCS="https://rpc1.gembascan.io https://rpc2.gembascan.io https://rpc3.gembascan.io"
LOCAL_EVM_RPC=http://localhost:8545              # archive exposes EVM RPC -> precise behind-tip gap
STUCK_BEHIND_BLOCKS=100
RESTART_COOLDOWN_SEC=900
MAX_CONSECUTIVE_RESTARTS=4
STATE_FILE=/var/lib/gemba/node-watchdog.state
LOG_FILE=/var/log/gemba-node-watchdog.log
NOTIFY_CMD=/usr/local/bin/gemba-alert-email.sh   # email on give-up (restart cap hit)
