# =============================================================================
# network.env — gemba-testnet-1 public network parameters (single source of truth
# for the installer). Edit only if you know what you are doing.
# =============================================================================

# Identity
NETWORK="gemba-testnet-1"
CHAIN_ID="gemba-testnet-1"
EVM_CHAIN_ID="821207"

# Genesis (bundled next to this file; sha256 is enforced by the installer)
GENESIS_SHA256="2ee72507b420443b23e0667f976d2d86c6b8bf7c88a8112e1145c2c8bf3bf3c9"

# Public seeds (the 3 backbone nodes; P2P TCP 26656)
SEEDS="44935754a7ea7e5ced5528eb39b5b4f6de73d3bb@13.140.139.82:26656,5473057935d09332c6051e7e83902ae226e060d2@13.140.139.83:26656,b7588b7dcd3e90bc0306dce68f7c95c5306d74a6@13.140.139.84:26656"

# Build-from-source: the node source is BUNDLED in ./src/chain (self-contained).
# The binary is built on YOUR machine -> matches your glibc. build-gembad.sh also
# fetches the pinned, PUBLIC cosmos/evm at build time.
GO_VERSION="1.25.9"

# Node config
MIN_GAS_PRICES="1000000000agmb"   # node mempool anti-spam floor
PRUNING="custom"                  # validators prune; explorer/archive use "nothing"
# I4 disk-fill hardening (bounds a pruned validator, prevents the .82/.83 overfill). Applied by
# install.sh only when PRUNING="custom". Retention window chosen 3 DAYS: the explorer does NOT read
# from validators (it reads the archive), so validator retention is irrelevant to the explorer — the
# 3-day window exists so the home i3 archive can catch up from a validator after a power/net outage
# of up to 3 days (fixes the .83 "no peer has the old blocks" recovery pain). For a tighter disk set
# both to 1 day = 34560; for looser catch-up margin raise them. tx_index off (Blockscout searches).
PRUNING_KEEP_RECENT="100000"      # ~3 days of STATE @ 2.5s (bounded ~10G; was 362880≈36G on the crash)
PRUNING_INTERVAL="10"
MIN_RETAIN_BLOCKS="100000"        # ~3 days of BLOCKS (~260MB) — archive catch-up window after an outage
TX_INDEX="null"                   # CometBFT tx index OFF on validators (13G tx_index.db was half the .82 fill)
MIN_SELF_BOND_GMB="1000"          # §5.2 — min self-delegation to create a validator

# Explorer / faucet (handy links)
EXPLORER_URL="https://testnet.gembascan.io"
