# --- GembaBlockchain ENDURANCE harness config (copy to .env; .env is gitignored) ---
# 24h LOW, CONSTANT, varied, revert-safe load on the PUBLIC testnet via the DNS RPCs.

# Public DNS RPCs (comma-separated). NEVER point at validators or the archive .137 directly.
# Each worker wallet is PINNED to one of these (reliability fix #1), so its nonce stream is
# consistent; load is still spread evenly across all three.
RPC_URLS=https://rpc1.gembascan.io,https://rpc2.gembascan.io,https://rpc3.gembascan.io

CHAIN_ID=821207

# Funder / deployer = the TESTNET founder key (valueless GMB). NEVER commit. Set in .env only.
# (wallet-backup/PRIVATE-KEYS.md `founder` 0x5578c75F… / stress/.env FUNDER_PK)
FUNDER_PK=

# Wallet pool (low is fine for a low-rate 24h run)
WALLET_COUNT=100
# Native GMB funded to each worker (TOP-UP to this target). 15 = generous 24h buffer
# (~3-5× needed); the drain step returns the unused part to the founder.
FUND_PER_WALLET=15

# Rate / shape
TARGET_TPS=4           # steady rate (3–6 is the sweet spot for clean 24h)
START_TPS=1
RAMP_SEC=300           # gentle warm-up so the state guards fill before steady
STEADY_SEC=86400       # 24h  (dry-run: set to 480)

# Pipeline / reliability
MAX_INFLIGHT_PER_WALLET=1   # 1 = no per-wallet nonce gaps over the WAN (ideal at low tps)
CONCURRENCY=20
SETTLE_MS=20000        # fallback time-gate; producer effects are confirmation-gated (on mine)
TX_TIMEOUT_MS=120000   # first timeout → re-broadcast once (fix #3); second → counted
RECEIPT_CONCURRENCY=6  # modest: public RPCs are ~25 r/s per IP behind nginx
DRAIN_MS=180000

# Gas (EIP-1559). Post-regenesis base-fee floor is 5 gwei; run.js bids 2×base+tip dynamically.
MAX_FEE_GWEI=15
PRIORITY_FEE_GWEI=2

# Logging
LOG_DIR=./logs
LOG_ROTATE_LINES=200000

# Node/disk probe is OPT-IN and OFF for the Pi run — we DO NOT touch the validators.
# (Leave COMETBFT_RPC unset. Setting it would probe a CometBFT host — don't, for this run.)
# COMETBFT_RPC=
# NODE_DATA_DIR=
# DISK_MIN_FREE_GB=12
