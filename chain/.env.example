# chain/.env — local devnet config (copy to chain/.env; chain/.env is gitignored).
# These are NOT secrets for any real network: the values below are the well-known PUBLIC
# cosmos-evm / evmd LOCAL-TEST credentials (see the upstream cosmos/evm repo's local_node.sh).
# They protect nothing — used ONLY against a localhost devnet that is wiped and re-created.
# NEVER fund these addresses or reuse them outside localhost. Real keys live in your secret
# store and are never committed (CLAUDE.md §3). The init/demo scripts require these to be set.

# Validator + dev account mnemonics (24 words). Fill from the upstream evmd local_node.sh,
# or generate your own with `gembad keys add <name>`.
VAL_MNEMONIC="<24-word validator mnemonic — devnet only>"
DEV0_MNEMONIC="<24-word dev0 mnemonic — devnet only>"
DEV1_MNEMONIC="<24-word dev1 mnemonic — devnet only>"

# dev0 EVM private key (0x...), used by the demo scripts for `cast send` on localhost only.
DEV0_PK="<0x dev0 private key — devnet only>"
