# === GembaBlockchain — .env.example (PLACEHOLDERS ONLY, committed) ===
# Copy to .env and fill in real values. NEVER commit .env (CLAUDE.md §3, §14).
# Real validator/node keys and mnemonics live in a secret store, NOT here and NOT in .env
# in plaintext where avoidable (Phase 9: KMS/Vault/tmkms).
#
# Services with their OWN committed templates (keep those authoritative for deploys):
#   services/contact-form/.env.example · services/purchase-backend/.env.example ·
#   services/blockchain-notifier/.env.example · explorer/envs/backend*.env.example ·
#   gemba-validator/auto/notify.env.example

# --- Chain identity (public, non-secret — kept here for one-stop config) ---
COSMOS_CHAIN_ID=gemba-1
EVM_CHAIN_ID=821206
COIN_DENOM=gmb
COIN_SYMBOL=GMB
COIN_TYPE=60

# --- Local devnet ---
MONIKER=gemba-devnet-node-0
# Keyring backend: use "test" ONLY on local devnet; "os"/"file" elsewhere.
KEYRING_BACKEND=test
# Mnemonic for a DEVNET-ONLY throwaway account. NEVER put a real mnemonic here.
DEV_MNEMONIC=replace-with-devnet-only-throwaway-mnemonic-do-not-use-in-prod

# --- Endpoints (CLAUDE.md §11) ---
COMETBFT_RPC_URL=http://localhost:26657
COSMOS_GRPC_URL=localhost:9090
COSMOS_REST_URL=http://localhost:1317
EVM_JSONRPC_HTTP=http://localhost:8545
EVM_JSONRPC_WS=ws://localhost:8546
P2P_PORT=26656

# --- Services backend (Phase 5: access-control API) ---
# App connects as the NON-superuser gemba_app role so RLS is enforced.
DATABASE_URL=postgresql://gemba_app:PASSWORD@localhost:5432/gemba
# Off-chain PII DB password — secret. Placeholder only.
DB_PASSWORD=replace-me
ACCESS_API_PORT=3001
# Deployed AccessControlNFT address (public, fine to set once deployed).
ACCESS_CONTROL_NFT_ADDRESS=0x...
# ISSUER_ROLE key that mints/revokes capability NFTs — SECRET, never commit.
ACCESS_ISSUER_PK=replace-with-devnet-only-issuer-key

# --- Explorer (Phase 7: Blockscout / GembaScan) ---
BLOCKSCOUT_API_KEY=replace-me
# GembaScan "My Account" login (docs/runbooks/explorer-account-login.md):
# Auth0 application creds + the Blockscout ACCOUNT_CLOAK_KEY (AES key for the
# accounts DB). All SECRET.
ACCOUNT_AUTH0_DOMAIN=your-tenant.eu.auth0.com
ACCOUNT_AUTH0_CLIENT_ID=replace-me
ACCOUNT_AUTH0_CLIENT_SECRET=replace-me
ACCOUNT_CLOAK_KEY=replace-me

# --- Buy-GMB (Phase 6: GembaPay -> GembaPayDispenser) ---
GEMBAPAY_API_KEY=replace-me
GEMBAPAY_API_SECRET=replace-me

# --- Testnet drip faucet (services/testnet-faucet) ---
TESTNET_EVM_RPC=http://localhost:8545
DRIP_AMOUNT_GMB=100
DRIP_COOLDOWN_MS=86400000
FAUCET_PORT=3002
# Testnet-only drip key (valueless tokens). NEVER a mainnet key. Secret.
FAUCET_KEY=replace-with-testnet-only-drip-key

# --- Bot protection for the public web properties ---
# Cloudflare Turnstile — gembachain.io landing forms:
GEMBACHAIN_TURNSTILE_SITE_KEY=replace-me
GEMBACHAIN_TURNSTILE_SECRET_KEY=replace-me
# Cloudflare Turnstile — contact-form service (see services/contact-form/.env.example):
TURNSTILE_SITE_KEY=replace-me
TURNSTILE_SECRET_KEY=replace-me
# Google reCAPTCHA (where Turnstile is not used):
RE_CAPTCHA_SITE_KEY=replace-me
RE_CAPTCHA_SECRET_KEY=replace-me

# --- GitHub ops token (fine-grained PAT) for repo / chain-registry automation. Secret. ---
# Note: fine-grained PATs cannot open PRs to external repos (the final PR click is manual).
GITHUB_TOKEN=replace-with-github-pat
