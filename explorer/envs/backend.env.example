# =============================================================================
# GembaScan (Blockscout) backend config for GembaBlockchain (EVM side).
# =============================================================================
# CRITICAL (CLAUDE.md §11): Blockscout must point at an ARCHIVE node (full
# history, pruning = "nothing"), NOT at a validator. Validators run PRUNED nodes
# for disk economy; the explorer needs every historical block/state/trace, so it
# reads from a dedicated archive full node. Set the URLs below to that archive
# node's EVM JSON-RPC.
# -----------------------------------------------------------------------------

# --- chain identity ---
CHAIN_ID=821207
NETWORK=GembaBlockchain
SUBNETWORK=GembaScan
COIN=GMB
COIN_NAME=GMB

# --- the ARCHIVE node's EVM JSON-RPC (8545 HTTP / 8546 WS). cosmos/evm is
#     geth-compatible (debug_traceBlockByNumber callTracer), so use the geth variant. ---
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_HTTP_URL=http://host.docker.internal:8565
ETHEREUM_JSONRPC_TRACE_URL=http://host.docker.internal:8565
ETHEREUM_JSONRPC_WS_URL=ws://host.docker.internal:8566
# internal txs come from debug_traceBlockByNumber (archive node)
INDEXER_INTERNAL_TRANSACTIONS_TRACER_TYPE=call_tracer

# --- database (the db service in docker-compose.yml) ---
DATABASE_URL=postgresql://blockscout:blockscout@db:5432/blockscout
# CHANGE for any non-local deployment; keep secrets out of git.
SECRET_KEY_BASE=REPLACE_WITH_64_HEX_CHARS_openssl_rand_hex_32

# --- API: Etherscan-compatible endpoint at /api, plus REST v2 / GraphQL ---
API_V1_READ_METHODS_DISABLED=false
API_V1_WRITE_METHODS_DISABLED=false
# Per-instance API keys are issued from the Account UI (ACCOUNT_ENABLED) and passed
# as ?apikey=... to the Etherscan-compatible /api endpoint (self-hosted => you set
# the rate limits). See README.
ACCOUNT_ENABLED=true
API_RATE_LIMIT=50
API_RATE_LIMIT_BY_KEY=100

# --- Account login (Auth0) + watchlist-notification mail (SendGrid) ---
# Login is handled by Auth0; SendGrid is ONLY for watchlist notification emails.
# Real values live in the gitignored backend.env (NEVER commit). Placeholders here:
ACCOUNT_CLOAK_KEY=base64-32-byte-key            # account DB field encryption
ACCOUNT_REDIS_URL=redis://redis:6379/1
ACCOUNT_AUTH0_DOMAIN=your-tenant.eu.auth0.com
ACCOUNT_AUTH0_CLIENT_ID=xxxxx
ACCOUNT_AUTH0_CLIENT_SECRET=xxxxx
ACCOUNT_SENDGRID_API_KEY=SG.xxxxx               # SendGrid -> watchlist emails only
ACCOUNT_SENDGRID_SENDER=no-reply@your-domain    # from an authenticated SendGrid domain
ACCOUNT_SENDGRID_TEMPLATE=d-xxxxxxxx            # SendGrid dynamic template id
# reCAPTCHA v2 (required by the account UI):
RE_CAPTCHA_CLIENT_KEY=xxxxx
RE_CAPTCHA_SECRET_KEY=xxxxx

# --- contract verification microservice (smart-contract-verifier service) ---
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://sc-verifier:8050
MICROSERVICE_SC_VERIFIER_TYPE=sc_verifier

# --- misc ---
ECTO_USE_SSL=false
DISABLE_EXCHANGE_RATES=true
