# === GembaBlockchain .gitignore ===
# This repo is PUBLIC. Never commit secrets (CLAUDE.md §3, §14).
# Public genesis ADDRESSES are fine; the private keys/mnemonics behind them are NOT.

# --- Secrets & env ---
.env
.env.*
!.env.example
*.secret
secrets/

# --- Wallet private-key backup (testnet re-genesis EOAs + validator accounts) ---
# NEVER commit. Local backup of /tmp/gemba-regenesis ephemeral keyring (see docs).
wallet-backup/

# --- Keys, mnemonics, keyrings (validator consensus keys, node keys, accounts) ---
*.key
*.pem
*priv*key*
*mnemonic*
*.mnemonic
keyring/
keyring-*/
node_key.json
priv_validator_key.json
priv_validator_state.json

# --- Cosmos / chain node data ---
.gembad/
.gemba/
data/
*.db

# --- Go ---
/chain/bin/
*.test
*.out

# --- Solidity / Foundry / Hardhat ---
/contracts/out/
/contracts/cache/
/contracts/broadcast/
/contracts/lib/
artifacts/
cache/
typechain-types/

# --- Node.js (services, frontend, explorer tooling) ---
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.next/
coverage/

# --- Explorer (Blockscout docker) volumes + real env (template is committed) ---
/explorer/blockscout-db-data/
/explorer/logs/
/explorer/envs/backend.env

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Claude Code local data (settings, transcripts) — never commit ---
.claude/

# alertmanager SMTP secret (never commit — repo is public)
smtp_password
monitoring/*.secret

# Local-only operational docs (auth/access maps) — never committed
*.local.md
